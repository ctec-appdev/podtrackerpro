# Core app URL used for Stripe redirects after Checkout finishes.
NEXT_PUBLIC_APP_URL=https://app.podtrackerpro.com

# Stripe secret key used only in server-side route handlers and webhook processing.
STRIPE_SECRET_KEY=sk_live_your_secret_key

# Stripe webhook signing secret from the configured webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Monthly subscription prices for PODTrackerPro plans.
STRIPE_PRICE_STARTER_MONTHLY=price_your_starter_monthly_price
STRIPE_PRICE_BUSINESS_MONTHLY=price_your_business_monthly_price

# Optional example if you later rename plans around a single Pro tier.
# STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly_price
